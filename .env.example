# Fluoro MVP backend environment example.
# Copy to .env in deployment environments and adjust paths as needed.

# Model bundle with weights, calibrators, OOD models, router config, and manifest.
FLUORO_BUNDLE_DIR=model_bundle

# Runtime database path used by the API when create_app() is called without an explicit db_path.
# The current FastAPI factory defaults to ${FLUORO_BUNDLE_DIR}/../feedback.sqlite;
# keep this value documented for deployment wrappers and process managers.
FLUORO_DB_PATH=runtime/fluoro_mvp.sqlite

# Optional image inference device override: cpu, cuda, or mps.
# If unset, the backend auto-detects cuda -> mps -> cpu.
FLUORO_IMAGE_DEVICE=cpu

# Uvicorn/API process settings for local serving.
FLUORO_API_HOST=0.0.0.0
FLUORO_API_PORT=8080

# Recommended runtime knobs for CPU/MPS local development.
OMP_NUM_THREADS=4
TOKENIZERS_PARALLELISM=false

